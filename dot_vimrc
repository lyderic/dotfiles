"Count line, words and characters of range
"if no range is provided: count from current line to end of file
function! CountInRange() range
	if a:firstline == a:lastline && a:firstline == line('.')
		let l:first = line('.')
		let l:last = line('$')
	else
		let l:first = a:firstline
		let l:last = a:lastline
	endif
	if l:first == l:last
		echon "Count in line " . l:first
	else
		echon "Count in lines " . l:first . "-" . l:last
	endif
	echon " (lines, words, chars):"
	execute l:first.",".l:last."w !wc -lwm"
endfunction
command! -nargs=0 -range CountInRange <line1>,<line2>call CountInRange()
nnoremap <leader>c :CountInRange<cr>
vnoremap <leader>c :CountInRange<cr>

"Search for string in dir/subdirs
function! Search(...)
	let l:selected = a:0 > 0 ? join(a:000) : ""
	if empty(l:selected)
		return
	endif
	"the following line is necessary to pre-filter out binary files
	"we don't use !grep directly as it causes an annoying flicker
	let l:filelist = systemlist('grep -FriIl ' . shellescape(l:selected) . ' .')
	if empty(l:filelist)
		cexpr []
		cclose
		redraw! | echo "No match: " . l:selected
		return
	endif
	try
		execute 'vimgrep /\V' . escape(l:selected, '/\') . '/j ' . join(map(l:filelist, 'fnameescape(v:val)'), ' ')
		copen
		redraw!
	catch /^Vim\%((\a\+)\)\=:E480/
		echo "'" . l:selected . "' not found"
	endtry
endfunction
command! -nargs=* Search call Search(<q-args>)
nnoremap <leader>s :Search 
