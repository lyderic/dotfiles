#!/usr/bin/env -S just --justfile

alias h := help

[private]
help:
	@$yo --list --unsorted --alias-style left --color always \
		--list-heading='' --list-prefix=' ' \
		| sed -e 's/alias: //' | awk 'NF'

test:
	# something to test

[private]
v:
	$yo --evaluate

yo := justfile()

set export
set shell := ["bash","-uc"]

